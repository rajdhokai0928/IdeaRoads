# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/idearoads

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────

# Random secret used to sign sessions — generate with: openssl rand -base64 32
APP_SECRET=change-me-to-a-long-random-string

# Public URL of the Workspace/Admin app (no trailing slash). Also the legacy
# single-origin URL name — keep it set even when using the two-host split below.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Two-host split: Workspace (Admin) vs Public Portal ────────
# Serving the two apps on separate hosts gives each its own session cookie
# (host-only cookies), so logging into one does NOT authenticate the other.
# See docs/migration/01-portal-subdomain-auth.md.
#
# Leave BOTH unset for a single-origin deployment (they default to
# NEXT_PUBLIC_APP_URL and nothing changes).
#
# Local dev: browsers resolve *.localhost to 127.0.0.1 automatically, so:
#   NEXT_PUBLIC_ADMIN_URL=http://app.localhost:3000
#   NEXT_PUBLIC_PORTAL_URL=http://portal.localhost:3000
# (If your browser/OS doesn't, add to /etc/hosts:
#   127.0.0.1 app.localhost portal.localhost
#  or use app.lvh.me:3000 / portal.lvh.me:3000 instead.)
#
# Production example:
#   NEXT_PUBLIC_ADMIN_URL=https://app.example.com
#   NEXT_PUBLIC_PORTAL_URL=https://portal.example.com
# Add BOTH hosts to your deployment project + TLS cert. For Google sign-in on
# both hosts, register each host's redirect URI in the Google console:
#   <host>/api/auth/callback/google
NEXT_PUBLIC_ADMIN_URL=
NEXT_PUBLIC_PORTAL_URL=

# ─────────────────────────────────────────────────────────────
# Email (SMTP) — required for magic-link sign-in
# ─────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password

# "From" address shown in delivered emails
EMAIL_FROM="IdeaRoads <noreply@example.com>"

# ─────────────────────────────────────────────────────────────
# Google OAuth — optional, enables "Continue with Google"
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
# ─────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Webhooks (optional)
# ─────────────────────────────────────────────────────────────

# Secret for validating inbound email webhook payloads
EMAIL_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# File storage — for profile picture uploads and other image uploads.
#
# Leave everything below blank and uploads are stored on local disk, under
# public/uploads (STORAGE_LOCAL_DIR to change the path). No setup needed —
# this is fine for a single-server/self-hosted deployment.
#
# To use AWS S3, Cloudflare R2, or any other S3-compatible provider instead,
# set all of STORAGE_S3_REGION / STORAGE_S3_BUCKET / STORAGE_S3_ACCESS_KEY_ID /
# STORAGE_S3_SECRET_ACCESS_KEY / STORAGE_PUBLIC_URL_BASE.
#
# AWS S3 example:
#   STORAGE_S3_REGION=us-east-1
#   STORAGE_S3_BUCKET=idearoads-uploads
#   STORAGE_S3_ACCESS_KEY_ID=AKIA...
#   STORAGE_S3_SECRET_ACCESS_KEY=...
#   STORAGE_S3_ENDPOINT=            (leave blank for AWS S3)
#   STORAGE_PUBLIC_URL_BASE=https://idearoads-uploads.s3.us-east-1.amazonaws.com
#
# Cloudflare R2 example:
#   STORAGE_S3_REGION=auto
#   STORAGE_S3_BUCKET=idearoads-uploads
#   STORAGE_S3_ACCESS_KEY_ID=...
#   STORAGE_S3_SECRET_ACCESS_KEY=...
#   STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_PUBLIC_URL_BASE=https://pub-xxxxxxxx.r2.dev
# ─────────────────────────────────────────────────────────────

STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_PUBLIC_URL_BASE=
STORAGE_LOCAL_DIR=
