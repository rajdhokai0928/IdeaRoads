# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:54329/idearoads

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────

# Random secret used to sign sessions — generate with: openssl rand -base64 32
APP_SECRET=change-me-to-a-long-random-string

# Public URL of this deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Email (SMTP) — required for magic-link sign-in
# ─────────────────────────────────────────────────────────────

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password

# "From" address shown in delivered emails
EMAIL_FROM="IdeaRoads <noreply@example.com>"

# ─────────────────────────────────────────────────────────────
# Google OAuth — optional, enables "Continue with Google"
# Create credentials at https://console.cloud.google.com/
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
# ─────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Webhooks (optional)
# ─────────────────────────────────────────────────────────────

# Secret for validating inbound email webhook payloads
EMAIL_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# File storage (Vercel Blob) — required for profile picture uploads
# Create a store at https://vercel.com/dashboard/stores and copy its token,
# or run `vercel blob store add` from the Vercel CLI.
# ─────────────────────────────────────────────────────────────

BLOB_READ_WRITE_TOKEN=
